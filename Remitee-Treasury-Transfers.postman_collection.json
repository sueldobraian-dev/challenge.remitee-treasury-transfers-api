{
	"info": {
		"_postman_id": "7a35fe60-47b1-4d33-bcbe-fb4e311029c7",
		"name": "Remitee Treasury Transfers API - E2E Tests",
		"description": "Colección de pruebas de extremo a extremo (E2E) para la API de Transferencias de Tesorería. Cubre flujos exitosos, control de duplicados (idempotencia) y todos los flujos de error lógicos del dominio.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Transferencia Exitosa - Misma Moneda (USD -> USD)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Generar un nuevo UUID/Guid único para esta transacción",
							"pm.collectionVariables.set(\"currentOperationId\", pm.variables.replaceIn('{{$guid}}'));"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is a valid JSON\", function () {",
							"    pm.response.to.be.withBody;",
							"    pm.response.to.be.json;",
							"});",
							"",
							"pm.test(\"Transaction details are correct\", function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.id).to.be.a('string').and.not.empty;",
							"    pm.expect(response.operationId).to.eql(pm.collectionVariables.get(\"currentOperationId\"));",
							"    pm.expect(response.status).to.eql(\"COMPLETED\");",
							"    pm.expect(response.sourceAccountId).to.eql(\"ACC-USD-1\");",
							"    pm.expect(response.targetAccountId).to.eql(\"ACC-USD-2\");",
							"    pm.expect(response.amountDebited).to.eql(10);",
							"    pm.expect(response.amountCredited).to.eql(10);",
							"    pm.expect(response.createdAt).to.exist;",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"operationId\": \"{{currentOperationId}}\",\n    \"sourceAccountId\": \"ACC-USD-1\",\n    \"targetAccountId\": \"ACC-USD-2\",\n    \"amount\": 10.00,\n    \"currency\": \"USD\",\n    \"fx\": null\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/transfers?api-version=1.0",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"transfers"
					],
					"query": [
						{
							"key": "api-version",
							"value": "1.0"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Idempotencia - Transferencia Duplicada (Conflict 409)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 409 Conflict\", function () {",
							"    pm.response.to.have.status(409);",
							"});",
							"",
							"pm.test(\"Response returns DUPLICATE_TRANSFER code\", function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.code).to.eql(\"DUPLICATE_TRANSFER\");",
							"    pm.expect(response.message).to.include(\"Duplicate transfer\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"operationId\": \"{{currentOperationId}}\",\n    \"sourceAccountId\": \"ACC-USD-1\",\n    \"targetAccountId\": \"ACC-USD-2\",\n    \"amount\": 10.00,\n    \"currency\": \"USD\",\n    \"fx\": null\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/transfers?api-version=1.0",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"transfers"
					],
					"query": [
						{
							"key": "api-version",
							"value": "1.0"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Transferencia Exitosa - Multidivisa con FX (USD -> ARS)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.collectionVariables.set(\"crossCurrencyOperationId\", pm.variables.replaceIn('{{$guid}}'));"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Amount is correctly multiplied by Fx rate\", function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.operationId).to.eql(pm.collectionVariables.get(\"crossCurrencyOperationId\"));",
							"    pm.expect(response.amountDebited).to.eql(5.00);",
							"    pm.expect(response.amountCredited).to.eql(5000.00); // 5.00 * 1000.00",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"operationId\": \"{{crossCurrencyOperationId}}\",\n    \"sourceAccountId\": \"ACC-USD-1\",\n    \"targetAccountId\": \"ACC-ARS-1\",\n    \"amount\": 5.00,\n    \"currency\": \"USD\",\n    \"fx\": 1000.00\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/transfers?api-version=1.0",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"transfers"
					],
					"query": [
						{
							"key": "api-version",
							"value": "1.0"
						}
					]
				}
			},
			"response": []
		},
